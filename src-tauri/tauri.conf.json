{
    "$schema":  "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName":  "Palworld Config Tool",
    "version":  "1.1.0",
    "identifier":  "com.h3202456.palworldconfigtool",
    "build":  {
                  "frontendDist":  "../dist",
                  "devUrl":  "http://localhost:5173",
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build"
              },
    "app":  {
                "windows":  [
                                {
                                    "label":  "main",
                                    "title":  "Palworld 中文可视化配置工具",
                                    "width":  1440,
                                    "height":  900,
                                    "minWidth":  1100,
                                    "minHeight":  720,
                                    "center":  true,
                                    "resizable":  true,
                                    "fullscreen":  false
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  [
                                   "nsis"
                               ],
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.ico"
                            ]
               },
    "mainBinaryName":  "palworld-config-tool"
}
